---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Work With Me" description="Fit/no‑fit statement and clear call to action.">
  <div class="hand-drawn-frame p-8">
    <h1 class="hand-drawn-heading text-3xl mb-6">Work With Me</h1>
    <p class="mb-4 text-gray-mid">I take on engagements that require deep engineering – trading infrastructure, fintech platforms, multi‑platform data‑integrity layers, and any system where correctness matters.</p>
    <p class="mb-6 text-gray-mid"><strong>Does NOT fit:</strong> simple brochure sites, generic marketing pages, or projects outside the engineering depth described above.</p>
    <a href="/contact" class="hand-drawn-cta">Get in Touch</a>
  </div>
</BaseLayout>