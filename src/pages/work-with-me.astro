---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Work With Me" description="Fit/no‑fit statement and clear call to action.">
  <h1 class="font-mono text-3xl mb-6">Work With Me</h1>
  <p class="mb-4">I take on engagements that require deep engineering – trading infrastructure, fintech platforms, multi‑platform data‑integrity layers, and any system where correctness matters.</p>
  <p class="mb-4"><strong>Does NOT fit:</strong> simple brochure sites, generic marketing pages, or projects outside the engineering depth described above.</p>
  <a href="/contact" class="inline-block px-6 py-2 border border-accent text-accent rounded hover:bg-accent hover:text-white transition">Get in Touch</a>
</BaseLayout>