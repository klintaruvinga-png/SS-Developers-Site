---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Now" description="Current focus and hardening work.">
  <div class="hand-drawn-frame p-8">
    <h1 class="hand-drawn-heading text-3xl mb-6">Now</h1>
    <ul class="list-disc pl-6 space-y-4 text-gray-mid">
      <li><strong>Currently Building</strong>
        <ul class="list-disc ml-6 mt-2 space-y-2">
          <li>SuperFIB Dashboard v4 / signal board reconciliation</li>
          <li>Stokvel Society – core features and final UI polish</li>
        </ul>
      </li>
      <li><strong>Currently Hardening</strong>
        <ul class="list-disc ml-6 mt-2 space-y-2">
          <li>Data‑integrity layer / broker feed reliability</li>
        </ul>
      </li>
    </ul>
  </div>
</BaseLayout>