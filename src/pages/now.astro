---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Now | SS Developers" description="A short snapshot of the software, hardening work, and current engineering focus I am on right now.">
  <section class="page-section">
    <div class="container page-hero-layout">
      <div class="section-head">
        <div class="page-intro">Now</div>
        <h1 class="page-title">What I am building and tightening right now.</h1>
        <p class="page-copy">
          This page stays short on purpose. It is a snapshot of the work that currently has my attention.
        </p>
      </div>

      <div class="manifest">
        <div class="manifest-row">
          <strong>Current bias</strong>
          <p>Less noise, more systems that can be trusted under imperfect operating conditions.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="page-section">
    <div class="container status-list">
      <article class="availability-card">
        <small>Currently building</small>
        <strong>SuperFIB dashboard v4</strong>
        <p>Signal board reconciliation, clearer operator state, and tighter dashboard behavior around execution visibility.</p>
      </article>

      <article class="availability-card">
        <small>Currently building</small>
        <strong>Stokvel Society</strong>
        <p>Core product features, stronger reporting flow, and final interface hardening around community finance clarity.</p>
      </article>

      <article class="availability-card">
        <small>Currently hardening</small>
        <strong>Data integrity and feed reliability</strong>
        <p>Staleness handling, source alignment, and the boring checks that keep distributed systems from quietly drifting.</p>
      </article>
    </div>
  </section>
</BaseLayout>
