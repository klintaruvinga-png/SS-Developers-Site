---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Projects" description="Case studies for SuperFIB and Stokvel Society.">
  <h1 class="hand-drawn-heading text-3xl mb-8">Projects</h1>
  <div class="grid md:grid-cols-2 gap-8">
    <!-- SuperFIB Card -->
    <article class="hand-drawn-card">
      <h2 class="font-mono text-2xl mb-3">SMC SuperFIB</h2>
      <p class="text-gray-mid mb-6">A distributed‑systems solution that synchronises a Pine Script indicator, a PHP/WordPress API, MT5 Expert Advisors and a React dashboard.</p>
      <a href="/projects/superfib" class="hand-drawn-cta">View case study</a>
    </article>
    <!-- Stokvel Society Card -->
    <article class="hand-drawn-card">
      <h2 class="font-mono text-2xl mb-3">Stokvel Society</h2>
      <p class="text-gray-mid mb-6">A fintech platform for community savings – member contributions flow into a trust‑layer ledger and are distributed as payouts.</p>
      <a href="/projects/stokvel" class="hand-drawn-cta">View case study</a>
    </article>
  </div>
</BaseLayout>