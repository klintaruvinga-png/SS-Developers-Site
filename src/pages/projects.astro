---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Projects" description="Case studies for SuperFIB and Stokvel Society.">
  <h1 class="font-mono text-3xl mb-6">Projects</h1>
  <div class="grid md:grid-cols-2 gap-8">
    <!-- SuperFIB Card -->
    <article class="bg-gray-soft p-4 rounded shadow-sm">
      <h2 class="font-mono text-2xl mb-2">SMC SuperFIB</h2>
      <p class="mb-4">A distributed‑systems solution that synchronises a Pine Script indicator, a PHP/WordPress API, MT5 Expert Advisors and a React dashboard.</p>
      <a href="/projects/superfib" class="inline-block px-4 py-2 border border-accent text-accent rounded hover:bg-accent hover:text-white transition">View case study</a>
    </article>
    <!-- Stokvel Society Card -->
    <article class="bg-gray-soft p-4 rounded shadow-sm">
      <h2 class="font-mono text-2xl mb-2">Stokvel Society</h2>
      <p class="mb-4">A fintech platform for community savings – member contributions flow into a trust‑layer ledger and are distributed as payouts.</p>
      <a href="/projects/stokvel" class="inline-block px-4 py-2 border border-accent text-accent rounded hover:bg-accent hover:text-white transition">View case study</a>
    </article>
  </div>
</BaseLayout>