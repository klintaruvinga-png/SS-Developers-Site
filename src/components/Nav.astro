---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/architecture', label: 'Architecture' },
  { href: '/how-i-work', label: 'How I work' },
  { href: '/work-with-me', label: 'Work with me' },
  { href: '/contact', label: 'Contact' },
  { href: '/now', label: 'Now' },
];
---
<header class="site-nav">
  <div class="nav-inner">
    <a href="/" class="brand-lockup" aria-label="SS Developers home">
      <span class="brand-emblem" aria-hidden="true"></span>
      <span class="brand-copy">
        <span class="brand-name">SS Developers</span>
        <span class="brand-note">Software where correctness matters</span>
      </span>
    </a>

    <nav class="nav-links nav-links-desktop" aria-label="Primary">
      {navItems.map((item) => {
        const normalizedHref = item.href.replace(/\/$/, '') || '/';
        return (
          <a href={item.href} aria-current={pathname === normalizedHref ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <a href="/contact" class="nav-cta nav-cta-desktop">Start a build</a>

    <details class="nav-mobile">
      <summary>Menu</summary>
      <div class="nav-mobile-panel">
        <nav class="nav-mobile-links" aria-label="Mobile">
          {navItems.map((item) => {
            const normalizedHref = item.href.replace(/\/$/, '') || '/';
            return (
              <a href={item.href} aria-current={pathname === normalizedHref ? 'page' : undefined}>
                {item.label}
              </a>
            );
          })}
        </nav>
        <a href="/contact" class="button-primary">Start a build</a>
      </div>
    </details>
  </div>
</header>
