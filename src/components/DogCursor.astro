---
// Hand‑drawn dog that follows the cursor and sits when the mouse stops.
---
<div id="dog-cursor" class="fixed inset-0 pointer-events-none z-50 opacity-90 hidden">
  <img src="/assets/dog.svg" alt="Hand‑drawn dog" class="w-20 h-20" />
</div>

<script>
  const dog = document.getElementById('dog-cursor');
  if (dog) {
    dog.classList.remove('hidden');
    let timeoutId = null;
    const idleDelay = 300; // ms without movement → sit
    const setPosition = (e) => {
      const x = e.clientX;
      const y = e.clientY;
      dog.style.transform = `translate(${x - 40}px, ${y - 40}px)`; // centre the 80px image
      dog.classList.remove('sitting');
      clearTimeout(timeoutId);
      timeoutId = setTimeout(() => {
        dog.classList.add('sitting');
      }, idleDelay);
    };
    window.addEventListener('mousemove', setPosition);
  }
</script>

<style>
  #dog-cursor {
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
  }

  #dog-cursor img {
    width: 5rem;
    height: auto;
    transform-origin: center center;
    transition: transform 0.18s ease-out, filter 0.18s ease-out;
    filter: drop-shadow(0 10px 20px rgba(17, 17, 17, 0.12));
  }

  #dog-cursor.sitting img {
    transform: translateY(8px) rotate(6deg) scale(0.96);
  }

  #dog-cursor.motion img {
    animation: wag 1.2s ease-in-out infinite;
  }

  @keyframes wag {
    0%, 100% {
      transform: translateY(0px) rotate(-1deg);
    }
    50% {
      transform: translateY(-1px) rotate(2deg);
    }
  }
</style>
