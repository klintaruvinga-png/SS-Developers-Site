---
const formspreeEndpoint = import.meta.env.FORMSPREE_ENDPOINT || "";
---
<form method="POST" action={formspreeEndpoint} class="contact-form">
  <div class="form-grid">
    <div class="field">
      <label for="contact-name">Name</label>
      <input id="contact-name" type="text" name="name" autocomplete="name" required placeholder="Your name" />
    </div>

    <div class="field">
      <label for="contact-email">Email</label>
      <input id="contact-email" type="email" name="email" autocomplete="email" required placeholder="you@company.com" />
    </div>

    <div class="field">
      <label for="project-type">Project type</label>
      <select id="project-type" name="project_type" required>
        <option value="">Select a category</option>
        <option>Trading infrastructure</option>
        <option>Fintech product</option>
        <option>Operations tooling</option>
        <option>Data integrity layer</option>
        <option>Other</option>
      </select>
    </div>

    <div class="field">
      <label for="timeline">Timeline</label>
      <select id="timeline" name="timeline" required>
        <option value="">Choose a window</option>
        <option>Immediate</option>
        <option>2 to 6 weeks</option>
        <option>1 to 3 months</option>
        <option>3 months or more</option>
      </select>
    </div>

    <div class="field field-full">
      <label for="message">What needs to be correct for this project to succeed?</label>
      <textarea id="message" name="message" rows="7" required placeholder="Give me the problem, the constraints, and what cannot fail."></textarea>
    </div>
  </div>

  <p class="form-note">
    I read every message myself. If the work is a fit, I will reply with next steps and the information I need to scope it properly.
  </p>

  <button type="submit" class="button-primary">Send project note</button>
</form>
